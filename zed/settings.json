// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // [SECTION] UI
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
    "opencode": {
      "type": "registry",
    },
  },
  "git_panel": {
    "tree_view": true,
  },
  "icon_theme": "Zed (Default)",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
  "soft_wrap": "editor_width",
  // [SECTION] Editor
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  // [SECTION] Languages
  "file_types": {
    "Helm": ["**/helm/**/*.yaml", "**/helm/**/*.yml"],
    "TOML": ["*.service"],
  },
  "languages": {
    "Python": {
      "language_servers": ["basedpyright", "ruff"],
      "format_on_save": "on",
    },
    "CSharp": {
      "language_servers": ["omnisharp", "!roslyn"],
    },
  },
  "lsp": {
    "ruff": {
      "settings": {
        "organizeImports": true,
        "autoImport": true,
      },
    },
  },
  // [SECTION] Remotes
  "ssh_connections": [],
  // [SECTION] AI
  "show_edit_predictions": true,
  "disable_ai": false,
  "edit_predictions": {
    "mode": "subtle",
  },
  "agent": {
    "single_file_review": true,
    "model_parameters": [],
    "use_modifier_to_send": true,
  },
  "context_servers": {},
  // [SECTION] Telemetry
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
}
